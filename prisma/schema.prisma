generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 用户模型
model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  username  String   @unique
  password  String
  avatar    String?
  bio       String?  @db.Text
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 书架设置
  bookshelfViewMode  String @default("grid") // grid, list, compact
  bookshelfSortBy    String @default("lastReadAt") // lastReadAt, favoritedAt, updatedAt, title
  bookshelfSortOrder String @default("desc") // asc, desc

  // 用户引导完成状态
  onboardingCompleted Boolean @default(false)

  // 关联
  favorites               Favorite[]
  bookLists               BookList[]
  likes                   Like[]
  comments                Comment[]
  commentLikes            CommentLike[]
  commentReports          CommentReport[]
  commentMentions         CommentMention[]
  ratings                 Rating[]
  novels                  Novel[]                  @relation("AuthorNovels")
  readHistory             ReadHistory[]
  following               Follow[]                 @relation("UserFollows")
  followers               Follow[]                 @relation("UserFollowers")
  activities              Activity[]
  initiatedTasks          ImportExportTask[]       @relation("TaskUser")
  adminTasks              ImportExportTask[]       @relation("TaskAdmin")
  shareLinks              ShareLink[]
  novelBackups            NovelBackup[]
  tagPreferences          UserTagPreference[]
  recommendationFeedbacks RecommendationFeedback[]

  @@map("users")
}

enum Role {
  USER
  ADMIN
}

// 小说模型
model Novel {
  id          Int         @id @default(autoincrement())
  title       String
  description String      @db.Text
  cover       String?
  authorId    Int
  status      NovelStatus @default(ONGOING)
  tags        String[]
  viewCount   Int         @default(0)
  isFeatured  Boolean     @default(false)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  // 关联
  author                  User                     @relation("AuthorNovels", fields: [authorId], references: [id])
  chapters                Chapter[]
  favorites               Favorite[]
  likes                   Like[]
  ratings                 Rating[]
  readHistory             ReadHistory[]
  activities              Activity[]
  periodStats             NovelPeriodStat[]
  rankingSnapshots        RankingSnapshot[]
  dailyStats              NovelDailyStat[]
  backups                 NovelBackup[]
  recommendationFeedbacks RecommendationFeedback[]

  @@map("novels")
}

enum NovelStatus {
  ONGOING
  COMPLETED
  HIATUS
}

// 章节状态枚举
enum ChapterStatus {
  DRAFT
  PUBLISHED
  SCHEDULED
}

// 章节模型
model Chapter {
  id          Int           @id @default(autoincrement())
  novelId     Int
  title       String
  content     String        @db.Text
  order       Int
  wordCount   Int           @default(0)
  status      ChapterStatus @default(PUBLISHED)
  scheduledAt DateTime?
  publishedAt DateTime?
  viewCount   Int           @default(0)
  readCount   Int           @default(0)
  finishCount Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  // 关联
  novel      Novel      @relation(fields: [novelId], references: [id], onDelete: Cascade)
  comments   Comment[]
  activities Activity[]

  @@unique([novelId, order])
  @@map("chapters")
}

// 评论模型（支持段落评论）
model Comment {
  id         Int      @id @default(autoincrement())
  userId     Int
  chapterId  Int
  content    String   @db.Text
  paragraph  Int? // 段落索引，null 表示章节级评论
  parentId   Int? // 父评论ID，用于回复
  isEdited   Boolean  @default(false)
  isPinned   Boolean  @default(false)
  isFeatured Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // 关联
  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  chapter  Chapter          @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  parent   Comment?         @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies  Comment[]        @relation("CommentReplies")
  likes    CommentLike[]
  reports  CommentReport[]
  mentions CommentMention[]
  Activity Activity[]

  @@map("comments")
}

// 收藏模型
model Favorite {
  id                 Int           @id @default(autoincrement())
  userId             Int
  novelId            Int
  createdAt          DateTime      @default(now())
  readingStatus      ReadingStatus @default(UNREAD)
  lastReadAt         DateTime?
  lastChapterId      Int?
  progress           Float         @default(0)
  lastViewedUpdateAt DateTime?
  hasNewUpdate       Boolean       @default(false)

  // 关联
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  novel         Novel          @relation(fields: [novelId], references: [id], onDelete: Cascade)
  bookListItems BookListItem[]

  @@unique([userId, novelId])
  @@map("favorites")
}

enum ReadingStatus {
  UNREAD
  READING
  FINISHED
}

// 书单模型
model BookList {
  id          Int      @id @default(autoincrement())
  userId      Int
  name        String
  description String?  @db.Text
  color       String?
  sortOrder   Int      @default(0)
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // 关联
  user   User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  items  BookListItem[]
  shares ShareLink[]

  @@unique([userId, name])
  @@index([userId, sortOrder])
  @@map("book_lists")
}

// 书单-小说关联模型
model BookListItem {
  id         Int      @id @default(autoincrement())
  bookListId Int
  favoriteId Int
  addedAt    DateTime @default(now())

  // 关联
  bookList BookList @relation(fields: [bookListId], references: [id], onDelete: Cascade)
  favorite Favorite @relation(fields: [favoriteId], references: [id], onDelete: Cascade)

  @@unique([bookListId, favoriteId])
  @@index([bookListId, addedAt])
  @@map("book_list_items")
}

// 点赞模型
model Like {
  id        Int      @id @default(autoincrement())
  userId    Int
  novelId   Int
  createdAt DateTime @default(now())

  // 关联
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  novel Novel @relation(fields: [novelId], references: [id], onDelete: Cascade)

  @@unique([userId, novelId])
  @@map("likes")
}

// 评分模型
model Rating {
  id        Int      @id @default(autoincrement())
  userId    Int
  novelId   Int
  score     Int // 1-5 分
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 关联
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  novel      Novel      @relation(fields: [novelId], references: [id], onDelete: Cascade)
  activities Activity[]

  @@unique([userId, novelId])
  @@map("ratings")
}

// 阅读历史
model ReadHistory {
  id            Int      @id @default(autoincrement())
  userId        Int
  novelId       Int
  lastChapterId Int?
  progress      Float    @default(0) // 0-100 百分比
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // 关联
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  novel Novel @relation(fields: [novelId], references: [id], onDelete: Cascade)

  @@unique([userId, novelId])
  @@map("read_history")
}

// 关注模型
model Follow {
  id          Int      @id @default(autoincrement())
  followerId  Int
  followingId Int
  createdAt   DateTime @default(now())

  // 关联
  follower  User @relation("UserFollows", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("UserFollowers", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@map("follows")
}

// 动态类型枚举
enum ActivityType {
  NOVEL_PUBLISHED
  CHAPTER_PUBLISHED
  COMMENT_POSTED
  RATING_SUBMITTED
}

// 用户动态模型
model Activity {
  id        Int          @id @default(autoincrement())
  userId    Int
  type      ActivityType
  novelId   Int?
  chapterId Int?
  commentId Int?
  ratingId  Int?
  metadata  String?      @db.Text
  createdAt DateTime     @default(now())

  // 关联
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  novel   Novel?   @relation(fields: [novelId], references: [id], onDelete: Cascade)
  chapter Chapter? @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  comment Comment? @relation(fields: [commentId], references: [id], onDelete: Cascade)
  rating  Rating?  @relation(fields: [ratingId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("activities")
}

// 评论点赞模型
model CommentLike {
  id        Int      @id @default(autoincrement())
  userId    Int
  commentId Int
  createdAt DateTime @default(now())

  // 关联
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([userId, commentId])
  @@map("comment_likes")
}

// 评论举报状态枚举
enum ReportStatus {
  PENDING
  RESOLVED
  IGNORED
}

// 评论举报类型枚举
enum ReportType {
  SPAM
  HARASSMENT
  HATE_SPEECH
  EXPLICIT_CONTENT
  OTHER
}

// 评论举报模型
model CommentReport {
  id        Int          @id @default(autoincrement())
  userId    Int
  commentId Int
  type      ReportType
  reason    String       @db.Text
  status    ReportStatus @default(PENDING)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  // 关联
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@map("comment_reports")
}

// 评论@提及模型
model CommentMention {
  id        Int      @id @default(autoincrement())
  commentId Int
  userId    Int
  createdAt DateTime @default(now())

  // 关联
  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
  @@map("comment_mentions")
}

// 排行榜周期类型
enum RankingPeriod {
  WEEK
  MONTH
  ALL
}

// 排行榜类型
enum RankingType {
  POPULARITY
  RATING
  FAVORITE
  NEW_BOOK
  COMPLETED
}

// 小说周期统计表 - 记录周/月的增量数据
model NovelPeriodStat {
  id            Int           @id @default(autoincrement())
  novelId       Int
  period        RankingPeriod
  periodKey     String // 格式：WEEK-2024-W01, MONTH-2024-01
  viewCount     Int           @default(0)
  favoriteCount Int           @default(0)
  ratingCount   Int           @default(0)
  ratingSum     Int           @default(0)
  avgRating     Float         @default(0)
  startDate     DateTime
  endDate       DateTime
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  novel Novel @relation(fields: [novelId], references: [id], onDelete: Cascade)

  @@unique([novelId, period, periodKey])
  @@index([period, periodKey])
  @@map("novel_period_stats")
}

// 排行榜快照表 - 记录每个周期的排名快照，用于计算排名变化
model RankingSnapshot {
  id          Int           @id @default(autoincrement())
  rankingType RankingType
  period      RankingPeriod
  periodKey   String
  novelId     Int
  rank        Int
  score       Float
  createdAt   DateTime      @default(now())

  novel Novel @relation(fields: [novelId], references: [id], onDelete: Cascade)

  @@unique([rankingType, period, periodKey, novelId])
  @@index([rankingType, period, periodKey, rank])
  @@map("ranking_snapshots")
}

// 排行榜缓存表 - 预计算的榜单数据
model RankingCache {
  id          Int           @id @default(autoincrement())
  rankingType RankingType
  period      RankingPeriod
  periodKey   String
  data        String        @db.Text // JSON格式的榜单数据
  updatedAt   DateTime      @updatedAt

  @@unique([rankingType, period, periodKey])
  @@map("ranking_caches")
}

// 小说每日统计表 - 记录每日详细数据
model NovelDailyStat {
  id                 Int      @id @default(autoincrement())
  novelId            Int
  date               DateTime @db.Date
  viewCount          Int      @default(0)
  favoriteCount      Int      @default(0)
  commentCount       Int      @default(0)
  chapterViewCount   Int      @default(0)
  chapterReadCount   Int      @default(0)
  chapterFinishCount Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  novel Novel @relation(fields: [novelId], references: [id], onDelete: Cascade)

  @@unique([novelId, date])
  @@index([novelId, date])
  @@map("novel_daily_stats")
}

// ==================== 导入导出功能相关模型 ====================

// 异步任务类型枚举
enum TaskType {
  USER_DATA_EXPORT
  ADMIN_NOVEL_EXPORT
  ADMIN_USER_EXPORT
  ADMIN_COMMENT_EXPORT
  ADMIN_NOVEL_IMPORT
  NOVEL_BACKUP
  NOVEL_RESTORE
}

// 任务状态枚举
enum TaskStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

// 异步导入导出任务表
model ImportExportTask {
  id             Int        @id @default(autoincrement())
  type           TaskType
  status         TaskStatus @default(PENDING)
  userId         Int? // 发起任务的用户ID
  adminId        Int? // 发起任务的管理员ID
  progress       Int        @default(0) // 0-100
  totalItems     Int        @default(0)
  processedItems Int        @default(0)
  fileName       String?
  filePath       String? // 相对于存储目录的路径
  fileSize       Int? // 字节
  downloadUrl    String?
  filters        String? // JSON格式的筛选条件
  fields         String? // JSON格式的导出字段
  result         String? // JSON格式的执行结果/错误信息
  errorMessage   String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  completedAt    DateTime?
  expiresAt      DateTime? // 文件过期时间

  user  User? @relation("TaskUser", fields: [userId], references: [id], onDelete: SetNull)
  admin User? @relation("TaskAdmin", fields: [adminId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([adminId, createdAt])
  @@index([status, createdAt])
  @@index([type, createdAt])
  @@map("import_export_tasks")
}

// 分享链接类型枚举
enum ShareType {
  BOOKSHELF
  BOOKLIST
}

// 分享链接表
model ShareLink {
  id          Int       @id @default(autoincrement())
  token       String    @unique
  type        ShareType
  userId      Int
  bookListId  Int? // 如果是书单分享
  title       String
  description String?   @db.Text
  coverImage  String? // 封面拼图URL
  data        String    @db.Text // JSON格式的分享数据快照
  viewCount   Int       @default(0)
  isExpired   Boolean   @default(false)
  expiresAt   DateTime? // 可选过期时间
  createdAt   DateTime  @default(now())

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookList BookList? @relation(fields: [bookListId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([token])
  @@map("share_links")
}

// 小说备份记录表
model NovelBackup {
  id           Int      @id @default(autoincrement())
  novelId      Int
  adminId      Int?
  fileName     String
  filePath     String // 相对于存储目录的路径
  fileSize     Int // 字节
  version      String // 备份格式版本号
  novelTitle   String
  chapterCount Int      @default(0)
  commentCount Int      @default(0)
  checksum     String // 文件校验和
  note         String?  @db.Text
  createdAt    DateTime @default(now())

  admin User?  @relation(fields: [adminId], references: [id], onDelete: SetNull)
  novel Novel? @relation(fields: [novelId], references: [id], onDelete: SetNull)

  @@index([novelId, createdAt])
  @@index([adminId, createdAt])
  @@map("novel_backups")
}

// ==================== 推荐系统相关模型 ====================

// 推荐类型枚举
enum RecommendationType {
  PERSONALIZED
  SIMILAR_USERS
  SIMILAR_TAGS
  COLD_START
}

// 用户标签偏好表 - 用于新用户冷启动时的标签选择
model UserTagPreference {
  id        Int      @id @default(autoincrement())
  userId    Int
  tag       String
  weight    Float    @default(1.0) // 标签权重，用于计算偏好强度
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, tag])
  @@index([userId])
  @@map("user_tag_preferences")
}

// 推荐反馈表 - 用户对推荐的反馈（如"不感兴趣"）
enum FeedbackType {
  DISLIKE
  NOT_INTERESTED
}

model RecommendationFeedback {
  id                 Int                 @id @default(autoincrement())
  userId             Int
  novelId            Int
  type               FeedbackType        @default(NOT_INTERESTED)
  recommendationType RecommendationType?
  createdAt          DateTime            @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  novel Novel @relation(fields: [novelId], references: [id], onDelete: Cascade)

  @@unique([userId, novelId, type])
  @@index([userId])
  @@map("recommendation_feedbacks")
}

// 推荐缓存表 - 预计算的个性化推荐结果
enum RecommendationCacheType {
  PERSONALIZED_FOR_YOU
  SIMILAR_NOVEL_USERS
  SIMILAR_NOVEL_TAGS
}

model RecommendationCache {
  id        Int                     @id @default(autoincrement())
  cacheType RecommendationCacheType
  targetId  Int // userId 或 novelId
  data      String                  @db.Text // JSON格式的推荐数据，包含推荐理由
  updatedAt DateTime                @updatedAt
  expiresAt DateTime?

  @@unique([cacheType, targetId])
  @@index([cacheType])
  @@map("recommendation_caches")
}

// 用户偏好分析缓存表 - 缓存用户的标签/作者偏好统计数据
model UserPreferenceCache {
  id            Int      @id @default(autoincrement())
  userId        Int      @unique
  tagWeights    String   @db.Text // JSON: {"tag1": 0.8, "tag2": 0.5}
  authorWeights String   @db.Text // JSON: {"authorId1": 0.9, "authorId2": 0.3}
  updatedAt     DateTime @updatedAt

  @@map("user_preference_caches")
}
