generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 用户模型
model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  username  String   @unique
  password  String
  avatar    String?
  bio       String?  @db.Text
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 关联
  favorites          Favorite[]
  likes              Like[]
  comments           Comment[]
  commentLikes       CommentLike[]
  commentReports     CommentReport[]
  commentMentions    CommentMention[]
  ratings            Rating[]
  novels             Novel[]       @relation("AuthorNovels")
  readHistory        ReadHistory[]
  following          Follow[]      @relation("UserFollows")
  followers          Follow[]      @relation("UserFollowers")
  activities         Activity[]

  @@map("users")
}

enum Role {
  USER
  ADMIN
}

// 小说模型
model Novel {
  id          Int         @id @default(autoincrement())
  title       String
  description String      @db.Text
  cover       String?
  authorId    Int
  status      NovelStatus @default(ONGOING)
  tags        String[]
  viewCount   Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  // 关联
  author      User          @relation("AuthorNovels", fields: [authorId], references: [id])
  chapters    Chapter[]
  favorites   Favorite[]
  likes       Like[]
  ratings     Rating[]
  readHistory ReadHistory[]
  activities  Activity[]

  @@map("novels")
}

enum NovelStatus {
  ONGOING
  COMPLETED
  HIATUS
}

// 章节模型
model Chapter {
  id        Int      @id @default(autoincrement())
  novelId   Int
  title     String
  content   String   @db.Text
  order     Int
  wordCount Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 关联
  novel      Novel      @relation(fields: [novelId], references: [id], onDelete: Cascade)
  comments   Comment[]
  activities Activity[]

  @@unique([novelId, order])
  @@map("chapters")
}

// 评论模型（支持段落评论）
model Comment {
  id        Int      @id @default(autoincrement())
  userId    Int
  chapterId Int
  content   String   @db.Text
  paragraph Int? // 段落索引，null 表示章节级评论
  parentId  Int? // 父评论ID，用于回复
  isEdited  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 关联
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  chapter    Chapter        @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  parent     Comment?       @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies    Comment[]      @relation("CommentReplies")
  likes      CommentLike[]
  reports    CommentReport[]
  mentions   CommentMention[]
  Activity   Activity[]

  @@map("comments")
}

// 收藏模型
model Favorite {
  id        Int      @id @default(autoincrement())
  userId    Int
  novelId   Int
  createdAt DateTime @default(now())

  // 关联
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  novel Novel @relation(fields: [novelId], references: [id], onDelete: Cascade)

  @@unique([userId, novelId])
  @@map("favorites")
}

// 点赞模型
model Like {
  id        Int      @id @default(autoincrement())
  userId    Int
  novelId   Int
  createdAt DateTime @default(now())

  // 关联
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  novel Novel @relation(fields: [novelId], references: [id], onDelete: Cascade)

  @@unique([userId, novelId])
  @@map("likes")
}

// 评分模型
model Rating {
  id        Int      @id @default(autoincrement())
  userId    Int
  novelId   Int
  score     Int // 1-5 分
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 关联
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  novel      Novel      @relation(fields: [novelId], references: [id], onDelete: Cascade)
  activities Activity[]

  @@unique([userId, novelId])
  @@map("ratings")
}

// 阅读历史
model ReadHistory {
  id            Int      @id @default(autoincrement())
  userId        Int
  novelId       Int
  lastChapterId Int?
  progress      Float    @default(0) // 0-100 百分比
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // 关联
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  novel Novel @relation(fields: [novelId], references: [id], onDelete: Cascade)

  @@unique([userId, novelId])
  @@map("read_history")
}

// 关注模型
model Follow {
  id          Int      @id @default(autoincrement())
  followerId  Int
  followingId Int
  createdAt   DateTime @default(now())

  // 关联
  follower  User @relation("UserFollows", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("UserFollowers", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@map("follows")
}

// 动态类型枚举
enum ActivityType {
  NOVEL_PUBLISHED
  CHAPTER_PUBLISHED
  COMMENT_POSTED
  RATING_SUBMITTED
}

// 用户动态模型
model Activity {
  id        Int          @id @default(autoincrement())
  userId    Int
  type      ActivityType
  novelId   Int?
  chapterId Int?
  commentId Int?
  ratingId  Int?
  metadata  String?      @db.Text
  createdAt DateTime     @default(now())

  // 关联
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  novel   Novel?   @relation(fields: [novelId], references: [id], onDelete: Cascade)
  chapter Chapter? @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  comment Comment? @relation(fields: [commentId], references: [id], onDelete: Cascade)
  rating  Rating?  @relation(fields: [ratingId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("activities")
}

// 评论点赞模型
model CommentLike {
  id        Int      @id @default(autoincrement())
  userId    Int
  commentId Int
  createdAt DateTime @default(now())

  // 关联
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([userId, commentId])
  @@map("comment_likes")
}

// 评论举报状态枚举
enum ReportStatus {
  PENDING
  RESOLVED
  IGNORED
}

// 评论举报类型枚举
enum ReportType {
  SPAM
  HARASSMENT
  HATE_SPEECH
  EXPLICIT_CONTENT
  OTHER
}

// 评论举报模型
model CommentReport {
  id        Int          @id @default(autoincrement())
  userId    Int
  commentId Int
  type      ReportType
  reason    String       @db.Text
  status    ReportStatus @default(PENDING)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  // 关联
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@map("comment_reports")
}

// 评论@提及模型
model CommentMention {
  id        Int      @id @default(autoincrement())
  commentId Int
  userId    Int
  createdAt DateTime @default(now())

  // 关联
  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
  @@map("comment_mentions")
}
